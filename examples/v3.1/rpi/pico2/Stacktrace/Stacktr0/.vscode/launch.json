{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Load (CMSIS-DAP)",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "Stacktr0.elf",
            "servertype": "openocd",
            "device": "RP2350",
            "gdbPath": "${env:RTK_GDB}",
            "objdumpPath": "${env:RTK_OBJDUMP}",
            "openOCDLaunchCommands": [
                "adapter speed 5000"
            ],
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/rp2350.cfg"
            ],
            "searchDir": [
                "${env:RTK_OPENOCD_RPI_SCRIPTS}"
            ],
            "serverpath": "${env:RTK_OPENOCD_RPI}",
            "svdFile": "${env:RTK_SVD_RP2350}",
            "postLaunchCommands": [
                "stepi",
                "monitor reset halt"
            ],
            "runToEntryPoint": "main"
        },
        {
            "name": "Attach (CMSIS-DAP)",
            "type": "cortex-debug",
            "request": "attach",
            "cwd": "${workspaceFolder}",
            "executable": "Stacktr0.elf",
            "servertype": "openocd",
            "device": "RP2350",
            "gdbPath": "${env:RTK_GDB}",
            "objdumpPath": "${env:RTK_OBJDUMP}",
            "openOCDLaunchCommands": [
                "adapter speed 5000"
            ],
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/rp2350.cfg"
            ],
            "searchDir": [
                "${env:RTK_OPENOCD_RPI_SCRIPTS}"
            ],
            "serverpath": "${env:RTK_OPENOCD_RPI}",
            "svdFile": "${env:RTK_SVD_RP2350}",
            "postAttachCommands": [
                "stepi",
                "monitor reset halt"
            ],
            "runToEntryPoint": "main"
        },
        {
            "name": "Load Core 0 (dual-core)",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "Stacktr0.elf",
            "servertype": "openocd",
            "device": "RP2350",
            "gdbPath": "${env:RTK_GDB}",
            "objdumpPath": "${env:RTK_OBJDUMP}",
            "openOCDLaunchCommands": [
                "set USE_SMP 0",
                "adapter speed 5000"
            ],
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/rp2350.cfg"
            ],
            "searchDir": [
                "${env:RTK_OPENOCD_RPI_SCRIPTS}"
            ],
            "serverpath": "${env:RTK_OPENOCD_RPI}",
            "svdFile": "${env:RTK_SVD_RP2350}",
            "postLaunchCommands": [
                "stepi",
                "monitor reset halt"
            ],
            "runToEntryPoint": "main",
            "chainedConfigurations": {
                "enabled": true,
                "waitOnEvent": "postInit",
                "detached": false,
                "lifecycleManagedByParent": true,
                "delayMs": 1000,
                "launches": [
                    {
                        "name": "Attach Core 1 (dual-core)",
                        "folder": "${workspaceFolder}"
                    }
                ]
            }
        },
        {
            "name": "Attach Core 1 (dual-core)",
            "type": "cortex-debug",
            "request": "attach",
            "cwd": "${workspaceFolder}",
            "executable": "Stacktr0.elf",
            "servertype": "external",
            "device": "RP2350",
            "gdbPath": "${env:RTK_GDB}",
            "objdumpPath": "${env:RTK_OBJDUMP}",
            "gdbTarget": "localhost:3334",
            "svdFile": "${env:RTK_SVD_RP2350}"
        }
    ]
}
