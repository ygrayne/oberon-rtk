{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Load S+NS (CMSIS-DAP)",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "executable": "sec/S.elf",
            "servertype": "openocd",
            "device": "RP2350",
            "gdbPath": "${env:RTK_GDB}",
            "objdumpPath": "${env:RTK_OBJDUMP}",
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/rp2350.cfg"
            ],
            "openOCDLaunchCommands": [
                "adapter speed 5000",
                "flash bank rp2350.ns_flash virtual 0x10400000 0 0 0 rp2350.cm0 rp2350.flash"
            ],
            "searchDir": [
                "${env:RTK_OPENOCD_RPI_SCRIPTS}"
            ],
            "serverpath": "${env:RTK_OPENOCD_RPI}",
            "svdFile": "${env:RTK_SVD_RP2350}",
            "loadFiles": [
                "${workspaceFolder}/sec/S.elf",
                "${workspaceFolder}/nonsec/NS.elf"
            ],
            "symbolFiles": [
                { "file": "${workspaceFolder}/sec/S.elf" },
                { "file": "${workspaceFolder}/nonsec/NS.elf" }
            ],
            "postLaunchCommands": [
                "stepi",
                "monitor reset halt"
            ],
            "runToEntryPoint": "S_startup"
        },
        {
            "name": "Attach S+NS (CMSIS-DAP)",
            "type": "cortex-debug",
            "request": "attach",
            "cwd": "${workspaceFolder}",
            "executable": "sec/S.elf",
            "servertype": "openocd",
            "device": "RP2350",
            "gdbPath": "${env:RTK_GDB}",
            "objdumpPath": "${env:RTK_OBJDUMP}",
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/rp2350.cfg"
            ],
            "openOCDLaunchCommands": [
                "adapter speed 5000",
                "flash bank rp2350.ns_flash virtual 0x10400000 0 0 0 rp2350.cm0 rp2350.flash"
            ],
            "searchDir": [
                "${env:RTK_OPENOCD_RPI_SCRIPTS}"
            ],
            "serverpath": "${env:RTK_OPENOCD_RPI}",
            "svdFile": "${env:RTK_SVD_RP2350}",
            "symbolFiles": [
                { "file": "${workspaceFolder}/sec/S.elf" },
                { "file": "${workspaceFolder}/nonsec/NS.elf" }
            ],
            "postAttachCommands": [
                "stepi",
                "monitor reset halt"
            ],
            "runToEntryPoint": "S_startup"
        }
    ]
}
