MODULE BUSCTRL_SYS;
(**
  Oberon RTK Framework
  Version: v3.1
  --
  BUSCTRL
  datasheet 12.15.4, p1240
  --
  MCU: RP2350
  --
  Copyright (c) 2024-2026 Gray gray@grayraven.org
  https://oberon-rtk.org/licences/
**)

  IMPORT BASE, RESETS_SYS, ACCESSCTRL_SYS;

  CONST
    BUSCTRL_BASE* = BASE.BUSCTRL_BASE;

    BUSCTRL_BUS_PRIORITY*     = BUSCTRL_BASE;
    BUSCTRL_BUS_PRIORITY_ACK* = BUSCTRL_BASE + 004H;
    BUSCTRL_PERFCTR_EN*       = BUSCTRL_BASE + 008H;
    BUSCTRL_PERFCTR0*         = BUSCTRL_BASE + 00CH;
    BUSCTRL_PERFSEL0*         = BUSCTRL_BASE + 010H;
    BUSCTRL_PERFCTR1*         = BUSCTRL_BASE + 014H;
    BUSCTRL_PERFSEL1*         = BUSCTRL_BASE + 018H;
    BUSCTRL_PERFCTR2*         = BUSCTRL_BASE + 01CH;
    BUSCTRL_PERFSEL2*         = BUSCTRL_BASE + 020H;
    BUSCTRL_PERFCTR3*         = BUSCTRL_BASE + 024H;
    BUSCTRL_PERFSEL3*         = BUSCTRL_BASE + 028H;

    (* PERFSEL events *)
    BUSCTRL_PS_APB_ACC_CONT*       = 00AH;
    BUSCTRL_PS_APB_ACC*            = 00BH;
    BUSCTRL_PS_FASTPERI_ACC_CONT*  = 00EH;
    BUSCTRL_PS_FASTPERI_ACC*       = 00FH;

    BUSCTRL_PS_SRAM9_ACC_CONT*     = 012H;
    BUSCTRL_PS_SRAM9_ACC*          = 013H;
    BUSCTRL_PS_SRAM8_ACC_CONT*     = 016H;
    BUSCTRL_PS_SRAM8_ACC*          = 017H;
    BUSCTRL_PS_SRAM7_ACC_CONT*     = 01AH;
    BUSCTRL_PS_SRAM7_ACC*          = 01BH;
    BUSCTRL_PS_SRAM6_ACC_CONT*     = 01EH;
    BUSCTRL_PS_SRAM6_ACC*          = 01FH;
    BUSCTRL_PS_SRAM5_ACC_CONT*     = 022H;
    BUSCTRL_PS_SRAM5_ACC*          = 023H;
    BUSCTRL_PS_SRAM4_ACC_CONT*     = 026H;
    BUSCTRL_PS_SRAM4_ACC*          = 027H;
    BUSCTRL_PS_SRAM3_ACC_CONT*     = 02AH;
    BUSCTRL_PS_SRAM3_ACC*          = 02BH;
    BUSCTRL_PS_SRAM2_ACC_CONT*     = 02EH;
    BUSCTRL_PS_SRAM2_ACC*          = 02FH;
    BUSCTRL_PS_SRAM1_ACC_CONT*     = 032H;
    BUSCTRL_PS_SRAM1_ACC*          = 033H;
    BUSCTRL_PS_SRAM0_ACC_CONT*     = 036H;
    BUSCTRL_PS_SRAM0_ACC*          = 037H;

    BUSCTRL_PS_XIP_MAIN1_ACC_CONT* = 03AH;
    BUSCTRL_PS_XIP_MAIN1_ACC*      = 03BH;
    BUSCTRL_PS_XIP_MAIN0_ACC_CONT* = 03EH;
    BUSCTRL_PS_XIP_MAIN0_ACC*      = 03FH;
    BUSCTRL_PS_ROM_ACC_CONT*       = 042H;
    BUSCTRL_PS_ROM_ACC*            = 043H;

    (* reset *)
    BUSCTRL_RST_reg* = RESETS_SYS.RESETS_RESET;
    BUSCTRL_RST_pos* = RESETS_SYS.RESETS_BUSCTRL;

    (* secure *)
    BUSCTRL_SEC_reg* = ACCESSCTRL_SYS.ACCESSCTRL_BUSCTRL;


END BUSCTRL_SYS.
